# База данных PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/oak_check"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Обязательно "true" если сервер запущен НЕ на localhost (на IP/домене).
# Без этого NextAuth v5 отвечает 404 на /api/auth/session → клиентская
# сессия ломается, в консоли видны ClientFetchError "Unexpected token '<'".
AUTH_TRUST_HOST="true"

# Pusher (для real-time)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Uploadthing (загрузка рендеров)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Resend (email уведомления)
RESEND_API_KEY=""
RESEND_FROM="noreply@oak3d.ru"
