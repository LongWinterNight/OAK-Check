# База данных PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/oak_check"

# NextAuth
NEXTAUTH_SECRET="your-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# Обязательно "true" если сервер запущен НЕ на localhost (на IP/домене).
# Без этого NextAuth v5 отвечает 404 на /api/auth/session → клиентская
# сессия ломается, в консоли видны ClientFetchError "Unexpected token '<'".
AUTH_TRUST_HOST="true"

# Папка для загруженных файлов (рендеры, аватарки).
# Используем Google Drive Desktop — указывай путь к синкаемой папке,
# тогда файлы автоматически уйдут в облако.
UPLOAD_DIR="D:\\OakCheck_Uploads"

# Email через Yandex SMTP (invite-flow, уведомления).
# SMTP_PASS — это «пароль приложения», НЕ обычный пароль от ящика:
#   id.yandex.ru → Пароли и авторизация → Пароли приложений → Создать → Почта
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_account@yandex.ru
SMTP_PASS=app_password_16_chars
SMTP_FROM="OAK·Check <your_account@yandex.ru>"

# Dev-аккаунт (только в NODE_ENV !== production).
# Используется для быстрого входа без регистрации.
DEV_USER_LOGIN=safan
DEV_USER_PASSWORD=your_dev_password
DEV_USER_NAME="Имя для dev-аккаунта"
