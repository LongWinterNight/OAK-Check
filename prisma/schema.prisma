generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          Role      @default(ARTIST)
  avatarUrl     String?
  passwordHash  String?
  online        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  lastSeenAt    DateTime?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  assignedShots   Shot[]       @relation("ShotAssignee")
  createdShots    Shot[]       @relation("ShotCreator")
  checkItems      CheckItem[]  @relation("ItemOwner")
  comments        Comment[]
  activities      Activity[]
  invitations     Invitation[] @relation("InvitationCreator")
  createdProjects Project[]    @relation("ProjectCreator")
  updatedProjects Project[]    @relation("ProjectUpdater")

  @@map("users")
}

enum Role {
  ARTIST
  LEAD
  QA
  POST
  PM
  ADMIN
}

model Project {
  id            String        @id @default(cuid())
  title         String
  client        String
  coverGradient String        @default("linear-gradient(135deg, #3a5a7a, #1a2a3a)")
  coverImage    String?
  status        ProjectStatus @default(ACTIVE)
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String?
  updatedById   String?

  shots     Shot[]
  createdBy User? @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("ProjectUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
  ARCHIVED
}

model Shot {
  id          String     @id @default(cuid())
  projectId   String
  code        String
  title       String
  resolution  String     @default("3840×2160")
  status      ShotStatus @default(TODO)
  assigneeId  String?
  createdById String?
  dueDate     DateTime?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner      User?           @relation("ShotAssignee", fields: [assigneeId], references: [id])
  createdBy  User?           @relation("ShotCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items      CheckItem[]
  comments   Comment[]
  versions   RenderVersion[]
  activities Activity[]
  chapters   Chapter[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([projectId, status])
  @@map("shots")
}

enum ShotStatus {
  TODO
  WIP
  REVIEW
  DONE
}

model Chapter {
  id     String @id @default(cuid())
  shotId String
  title  String
  order  Int    @default(0)

  shot  Shot        @relation(fields: [shotId], references: [id], onDelete: Cascade)
  items CheckItem[]

  @@map("chapters")
}

model CheckItem {
  id        String    @id @default(cuid())
  shotId    String
  chapterId String
  title     String
  state     ItemState @default(TODO)
  ownerId   String?
  note      String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shot    Shot    @relation(fields: [shotId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  owner   User?   @relation("ItemOwner", fields: [ownerId], references: [id])

  @@index([shotId])
  @@index([chapterId])
  @@index([ownerId])
  @@index([shotId, state])
  @@map("check_items")
}

enum ItemState {
  TODO
  WIP
  DONE
  BLOCKED
}

model Comment {
  id        String   @id @default(cuid())
  shotId    String
  versionId String?
  userId    String
  body      String
  pinX      Float?
  pinY      Float?
  parentId  String?
  createdAt DateTime @default(now())
  editedAt  DateTime?

  shot    Shot           @relation(fields: [shotId], references: [id], onDelete: Cascade)
  version RenderVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  user    User           @relation(fields: [userId], references: [id])
  parent  Comment?       @relation("Replies", fields: [parentId], references: [id])
  replies Comment[]      @relation("Replies")

  @@index([shotId])
  @@index([versionId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model RenderVersion {
  id           String   @id @default(cuid())
  shotId       String
  version      String
  url          String
  thumbnailUrl String?
  format       String   @default("EXR")
  resolution   String   @default("3840×2160")
  fileSize     Int?
  createdAt    DateTime @default(now())

  shot     Shot      @relation(fields: [shotId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([shotId])
  @@map("render_versions")
}

model ChecklistTemplate {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("Общее")
  description String?
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())

  items TemplateItem[]

  @@map("checklist_templates")
}

model TemplateItem {
  id         String @id @default(cuid())
  templateId String
  title      String
  order      Int    @default(0)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_items")
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  shotId    String?
  type      ActivityType
  message   String
  createdAt DateTime     @default(now())

  user User  @relation(fields: [userId], references: [id])
  shot Shot? @relation(fields: [shotId], references: [id])

  @@index([userId])
  @@index([shotId])
  @@index([createdAt])
  @@index([type])
  @@map("activities")
}

model Invitation {
  id        String    @id @default(cuid())
  email     String
  role      Role      @default(ARTIST)
  token     String    @unique @default(cuid())
  createdBy String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  creator User? @relation("InvitationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdBy])
  @@index([expiresAt])
  @@map("invitations")
}

enum ActivityType {
  ITEM_STATE_CHANGED
  ITEM_CREATED
  COMMENT_ADDED
  VERSION_UPLOADED
  SHOT_STATUS_CHANGED
  MEMBER_ADDED
  USER_ROLE_CHANGED
  USER_DELETED
  INVITE_CREATED
  INVITE_REVOKED
}
